[sub_resource type="GDScript" id="GDScript_7u77a"]
resource_name = "Main"
script/source = "extends Node2D

@export_group(\"KeyBoards\")
@export var currentBoard : Node2D
@export var counterBoard : int = 1


@export_group(\"Dialogue\")
@export var dialogue_key : String

@export_group(\"Controls\")
@export var arrows : Sprite2D
@export var dpad : Sprite2D
@export var zbutton : Sprite2D
@export var facebutton : Sprite2D
@export var arrows_zbutton : Sprite2D
@export var dpad_facebutton : Sprite2D

var interactiveNum : int = 0
# BOOLS for the items

var car : bool = false
var wii : bool = false
var pizza : bool = false
var cards : bool = false

var play_screen : bool = false

var car_controls : bool = false
var card_controls: bool = false
var pizza_controls : bool = false
var wii_controls : bool = false

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	# Play Static
	SoundManager.fade_in_bgs(\"Static\",2.0)
	await get_tree().create_timer(3).timeout
	#try_focus() # TEST
	# VM Logo
	fade_tween($Logo)
	await get_tree().create_timer(7).timeout
	# Some space here 
	
	#Shrink circle
	var tween = create_tween()
	SoundManager.play_sfx(\"Zoom\")
	tween.tween_property($Foreground, \"scale\", Vector2(1,1),5)
	await tween.finished
	await get_tree().create_timer(4).timeout
	fade_tween_in($Title)
	SoundManager.fade_in_bgm(\"BG_Title\",2.0)
	await get_tree().create_timer(4).timeout
	$Button.show()
	await get_tree().create_timer(1).timeout
	play_screen = true

func start():
	# read the dialogue JSON file
	DialogueManager.readJSON(\"res://Dialogue/RMBA_dialogue.json\")
	# connect signals that'll be used in the game
	signals_connected()
	fade_tween_in($I1)
	SoundManager.fade_into_bgm(\"BG_Flat\",\"BG_Title\",5.0,0,-15)
	await get_tree().create_timer(4.0).timeout
	#activate_moment($LetterMoment)
	#introsky()
	dialogue_go(dialogue_key)

func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventJoypadMotion:
		return
	if event.is_pressed():
		# don't do anything if play_screen isn't up
		if play_screen == false:
			return
		else:
			play_screen = false
			$Button.hide()
			SoundManager.play_mfx(\"Select\",0,5)
			await get_tree().create_timer(0.5).timeout
			fade_tween_out($Title)
			await get_tree().create_timer(7).timeout
			start()

func _input(event: InputEvent) -> void:
	if event is InputEventKey or event is InputEventMouse:
		# for car
		if car_controls == true: 
			arrows.show()
			dpad.hide()
		elif card_controls == true: 
			zbutton.show()
			facebutton.hide()
		elif pizza_controls == true: 
			zbutton.show()
			facebutton.hide()
		elif wii_controls == true: 
			arrows_zbutton.show()
			dpad_facebutton.hide()
	elif event is InputEventJoypadButton or event is InputEventJoypadMotion:
		# for car
		if car_controls == true:
			dpad.show()
			arrows.hide()
		elif card_controls == true: 
			facebutton.show()
			zbutton.hide()
		elif pizza_controls == true: 
			facebutton.show()
			zbutton.hide()
		elif wii_controls == true: 
			dpad_facebutton.show()
			arrows_zbutton.hide()

func signals_connected():
	DialogueManager.keyboard_image.connect(keyboard_next)
	DialogueManager.intro_over.connect(introsky)
	DialogueManager.circles_appear.connect(circles_appear)
	DialogueManager.mini_done_signaled.connect(mini_done_reset)
	
	DialogueManager.letter_signaled.connect(lettersetup)
	
	DialogueManager.fade_out_sky.connect(fade_out_sky)
	DialogueManager.fade_in_sky.connect(fade_in_sky)
	
	DialogueManager.endgame_signaled.connect(enclose)
	pass


func introsky():
	# enlarge the foreground and I12
	var tween = get_tree().create_tween()
	tween.tween_property($Foreground, \"scale\", Vector2(15,15), 30)
	tween.parallel().tween_property($I10, \"scale\", Vector2(15,15), 30)
	SoundManager.play_sfx(\"Zoom\")
	# wait for some time
	await get_tree().create_timer(4).timeout
	# tween the night sky to invisible to reveal glowing sky
	var tween2 = get_tree().create_tween()
	tween2.tween_property($BackgroundNew,\"modulate:a\",0.78,6)
	SoundManager.fade_into_bgm(\"BG_Title\",\"BG_Flat\",4.0,0,-15)
	await get_tree().create_timer(5).timeout
	dialogue_go(\"EndIntro\")
	pass

func circles_appear():
	await get_tree().create_timer(2).timeout
	$Circles.visible = true
	if car:
		$Circles/CarIcon.visible = false
	if cards:
		$Circles/CardsIcon.visible = false
	if pizza: 
		$Circles/PizzaIcon.visible = false
	if wii: 
		$Circles/WiiIcon.visible = false
	var tween = get_tree().create_tween()
	tween.tween_property($Circles,\"modulate:a\",1,3)
	await tween.finished
	# fade in the character on the stilts
	fade_tween_in($CharacterStilts)
	# turn on clickable access for each section
	$Circles/CardsIcon.disabled = false
	$Circles/CarIcon.disabled = false
	$Circles/PizzaIcon.disabled = false
	$Circles/WiiIcon.disabled = false
	# and the focuse modes turned on
	$Circles/CardsIcon.focus_mode = Control.FOCUS_ALL
	$Circles/CarIcon.focus_mode = Control.FOCUS_ALL
	$Circles/PizzaIcon.focus_mode = Control.FOCUS_ALL
	$Circles/WiiIcon.focus_mode = Control.FOCUS_ALL
	try_focus()

func disable_collisions():
	$Circles/CardsIcon.disabled = true
	$Circles/CarIcon.disabled = true
	$Circles/PizzaIcon.disabled = true
	$Circles/WiiIcon.disabled = true
	# and the focus
	$Circles/CardsIcon.focus_mode = Control.FOCUS_NONE
	$Circles/CarIcon.focus_mode = Control.FOCUS_NONE
	$Circles/PizzaIcon.focus_mode = Control.FOCUS_NONE
	$Circles/WiiIcon.focus_mode = Control.FOCUS_NONE

func disable_controls():
	arrows.hide()
	arrows_zbutton.hide()
	dpad.hide()
	dpad_facebutton.hide()
	facebutton.hide()
	zbutton.hide()
	
	wii_controls = false
	pizza_controls = false
	car_controls = false
	card_controls = false

func try_focus():
	var icon_array = $Circles.get_children()
	print(icon_array)
	var focus_grabbed : bool = false
	for icon in icon_array:
		if icon.visible == true:
			if focus_grabbed == false:
				icon.grab_focus()
				focus_grabbed = true
	focus_grabbed = false

func mini_done_reset():
	disable_controls()
	if interactiveNum >= 4:
		for moment in get_children():
			if moment.has_method(\"deactivate\"):
				fade_tween_out(moment)
				await get_tree().create_timer(.5).timeout
				moment.deactivate()
		SoundManager.stop(\"Car\")
		SoundManager.fade_into_bgm(\"BG_Flat\",\"BG_Title\",4.0,0,-15)
		await get_tree().create_timer(3.0).timeout
		dialogue_go(\"OffRamp\")
		# another function to review the boards
	else: 
		circles_appear()


func enclose():
	# this is the updated end - fade to black and go to the next scene
	await get_tree().create_timer(5).timeout
	SoundManager.fade_out(\"BG_Letter\",2.0)
	fade_tween_in($Black)
	await get_tree().create_timer(4).timeout
	SoundManager.stop_all()
	await get_tree().create_timer(6).timeout
	get_tree().change_scene_to_file(\"res://Scenes/end.tscn\")


func lettersetup():
	await get_tree().create_timer(4).timeout
	fade_tween_out($I16)
	fade_tween_in($Black)
	await get_tree().create_timer(2).timeout
	SoundManager.stop_all()
	await get_tree().create_timer(8).timeout
	fade_tween_out($Black)
	await get_tree().create_timer(2).timeout
	var tween2 = get_tree().create_tween()
	tween2.tween_property($BackgroundNew,\"modulate:a\",0.78,6)
	activate_moment($LetterMoment)
	fade_tween_in($LetterMoment)
	await get_tree().create_timer(4.0).timeout
	dialogue_go(\"Letter\")
	await get_tree().create_timer(3).timeout
	SoundManager.fade_in_bgm(\"BG_Letter\",2.0,0,-15)
	
# ACTIVATE THE PROCESS MOMENT
func activate_moment(target_moment: Node):
	for moment in get_children():
		if moment.has_method(\"deactivate\"):
			moment.deactivate()
	target_moment.activate()

# SIGNAL FUNCTIONS CLICKS
func _on_car_icon_pressed() -> void:
	if not car:
		car = true
		SoundManager.play_mfx(\"Select\")
		fade_tween_out($Circles)
		fade_tween_out($CharacterStilts)
		# add some time in between selecting and starting the moment
		get_tree().create_timer(3.0).timeout
		activate_moment($CarMoment)
		fade_tween_in($CarMoment)
		# Check For Controller
		car_controls = true
		disable_collisions()
		interactiveNum += 1
		await get_tree().create_timer(4.0).timeout
		$Circles.visible = false
		dialogue_go(\"PaperCar\")

func _on_cards_icon_pressed() -> void:
	if not cards:
		SoundManager.stop(\"Car\")
		cards = true
		SoundManager.play_mfx(\"Select\")
		fade_tween_out($Circles)
		fade_tween_out($CharacterStilts)
		get_tree().create_timer(3.0).timeout
		activate_moment($CardMoment)
		fade_tween_in($CardMoment)
		card_controls = true
		disable_collisions()
		interactiveNum += 1
		await get_tree().create_timer(4.0).timeout
		$Circles.visible = false
		dialogue_go(\"PaperCards\")

func _on_wii_icon_pressed() -> void:
	if not wii:
		wii = true
		SoundManager.stop(\"Car\")
		SoundManager.play_mfx(\"Select\")
		fade_tween_out($Circles)
		fade_tween_out($CharacterStilts)
		get_tree().create_timer(3.0).timeout
		activate_moment($WiiMoment)
		fade_tween_in($WiiMoment)
		wii_controls = true
		disable_collisions()
		interactiveNum += 1
		await get_tree().create_timer(4.0).timeout
		$Circles.visible = false
		dialogue_go(\"WiiBowling\")

func _on_pizza_icon_pressed() -> void:
	if not pizza:
		pizza = true
		SoundManager.stop(\"Car\")
		SoundManager.play_mfx(\"Select\")
		fade_tween_out($Circles)
		fade_tween_out($CharacterStilts)
		get_tree().create_timer(3.0).timeout
		activate_moment($PizzaMoment)
		fade_tween_in($PizzaMoment)
		pizza_controls = true
		disable_collisions()
		interactiveNum += 1
		await get_tree().create_timer(4.0).timeout
		$Circles.visible = false
		dialogue_go(\"PaperPizza\")



# HELPER FUNCTIONS
func dialogue_go(dialogue_key):
	DialogueManager.dialogue_player(dialogue_key)

func keyboard_next():
	# turn off previous board
	fade_tween_out(currentBoard)
	counterBoard +=1
	currentBoard = get_node(\"I\" + str(counterBoard))
	await get_tree().create_timer(0.5).timeout
	fade_tween_in(currentBoard)

func fade_tween(image) -> void:
	var fadeTween = get_tree().create_tween()
	fadeTween.tween_property(image,\"modulate\",Color(1.0, 1.0, 1.0, 1.0), 2)
	fadeTween.tween_interval(3)
	fadeTween.tween_property(image,\"modulate\",Color(1.0, 1.0, 1.0, 0.0), 2)

func fade_tween_in(image) -> void:
	var fadeTween = get_tree().create_tween()
	fadeTween.tween_property(image,\"modulate\",Color(1.0, 1.0, 1.0, 1.0), 2)

func fade_tween_out(image) -> void:
	var fadeTween = get_tree().create_tween()
	fadeTween.tween_property(image,\"modulate\",Color(1.0, 1.0, 1.0, 0.0), 2)

func fade_in_sky():
	var tween2 = get_tree().create_tween()
	tween2.tween_property($BackgroundNew,\"modulate:a\",0.78,1.5)

func fade_out_sky():
	var tween2 = get_tree().create_tween()
	tween2.tween_property($BackgroundNew,\"modulate:a\",0.78,1.5)
"

